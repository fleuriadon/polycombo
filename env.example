# PolyCombo API Configuration

# Network
RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY
CHAIN_ID=80002

# Deployed contract addresses
FACTORY_ADDRESS=0x...
VAULT_ADDRESS=0x...
USDC_ADDRESS=0x...

# Mode: 'true' for testnet simulation, 'false' for production
SIMULATION_MODE=true

# Gelato Relay (gasless transactions)
GELATO_API_KEY=your_gelato_api_key

# Server
PORT=3000
